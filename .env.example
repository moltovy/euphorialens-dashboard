# Public dashboard data feed. Required in Vercel production.
EUPHORIA_PUBLIC_DASHBOARD_URL=https://example.com/gold/public/public-dashboard.json

# Optional split public data base. If unset, the app derives this from EUPHORIA_PUBLIC_DASHBOARD_URL.
EUPHORIA_PUBLIC_DATA_BASE_URL=https://example.com/gold/public/

# Optional public asset CDN/R2 base. If unset, the dashboard uses local lightweight fallback media.
NEXT_PUBLIC_EUPHORIA_ASSET_BASE_URL=

# Optional official Euphoria public app data source. Do not put private cookies or browser sessions here.
EUPHORIA_OFFICIAL_API_BASE_URL=https://api.mainnet.euphoria.finance
EUPHORIA_OFFICIAL_LEADERBOARD_URL=
EUPHORIA_OFFICIAL_REVALIDATE_SECONDS=300
EUPHORIA_OFFICIAL_FETCH_TIMEOUT_MS=5000
